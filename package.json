    "@supabase/supabase-js": "^2.98.0",
    "expo": "~55.0.5",
    "expo-constants": "~55.0.7",
    "expo-device": "~55.0.9",
    "expo-font": "^55.0.4",
    "expo-linking": "^55.0.7",
    "expo-notifications": "~55.0.11",
    "expo-router": "^55.0.4",
    "expo-splash-screen": "^55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "^55.0.9",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
