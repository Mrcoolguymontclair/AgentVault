# Supabase (required for app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Functions (set in Supabase dashboard → Edge Functions → Secrets)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Alpaca Paper Trading (set in Supabase dashboard → Edge Functions → Secrets)
# ALPACA_API_KEY=your-alpaca-key
# ALPACA_API_SECRET=your-alpaca-secret
# ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# Groq AI (set in Supabase dashboard → Edge Functions → Secrets)
# GROQ_API_KEY_1=your-groq-key
# GROQ_API_KEY_2=optional-rotation-key
# GROQ_API_KEY_3=optional-rotation-key
